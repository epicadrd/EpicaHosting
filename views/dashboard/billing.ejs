<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title || 'Facturación' %> | <%= appName || 'Epic Hosting' %></title>

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css"/>
  <link rel="stylesheet" href="/css/dashboard.css"/>

  <style>
    .billing-layout{
      display:grid;
      grid-template-columns: 1.1fr .9fr;
      gap:18px;
    }

    .invoice-table{
      display:grid;
      gap:12px;
    }

    .invoice-row{
      display:grid;
      grid-template-columns: 1.1fr .8fr .8fr .9fr auto;
      gap:12px;
      align-items:center;
      padding:16px;
      border-radius:18px;
      background:rgba(255,255,255,.035);
      border:1px solid rgba(255,255,255,.06);
    }

    .invoice-head{
      font-size:.82rem;
      color:#94a3b8;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.04em;
      background:transparent;
      border:none;
      padding:0 4px;
    }

    .payment-method-wrap{
      display:flex;
      justify-content:flex-start;
      align-items:flex-start;
      flex-wrap:wrap;
    }

    .pm-card{
      width:100%;
      max-width:340px;
      padding:18px;
      border-radius:20px;
      background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.025));
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 14px 30px rgba(0,0,0,.16);
    }

    .pm-chip{
      display:inline-flex;
      padding:7px 12px;
      border-radius:999px;
      background:rgba(139,92,246,.12);
      border:1px solid rgba(139,92,246,.24);
      color:#ddd6fe;
      font-weight:800;
      font-size:.8rem;
      margin-bottom:14px;
    }

    .status-mini{
      display:inline-flex;
      padding:6px 10px;
      border-radius:999px;
      font-size:.8rem;
      font-weight:800;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(255,255,255,.05);
    }

    .empty-box{
      padding:22px;
      border-radius:20px;
      background:rgba(255,255,255,.035);
      border:1px solid rgba(255,255,255,.06);
      color:#94a3b8;
      line-height:1.8;
    }

    @media (max-width: 980px){
      .billing-layout{
        grid-template-columns: 1fr;
      }

      .invoice-row{
        grid-template-columns: 1fr;
      }

      .invoice-head{
        display:none;
      }

      .pm-card{
        max-width:100%;
      }
    }
  </style>
</head>
<body>

<header class="navbar">
  <div class="container nav-wrap">
    <a href="/" class="brand">
      <span class="brand-mark">⚡</span>
      <span><%= appName %></span>
    </a>

    <nav class="nav-links">
      <a href="/dashboard">Dashboard</a>
      <a href="/dashboard/plans">Planes</a>
      <form action="/logout" method="POST">
        <button class="nav-cta">Cerrar sesión</button>
      </form>
    </nav>
  </div>
</header>

<main class="dashboard-main">
<section class="dashboard-section">
<div class="dashboard-shell">

  <div class="dashboard-topbar">
    <div>
      <span class="kicker">
        <span class="kicker-dot"></span>
        Facturación
      </span>
      <h1>Facturas y tarjeta</h1>
      <p>Desde aquí puedes revisar tus facturas emitidas y el método de pago guardado.</p>
    </div>

    <div class="topbar-actions">
      <a href="/dashboard" class="btn btn-secondary">Volver al dashboard</a>
    </div>
  </div>

  <div class="billing-layout">

    <section class="panel">
      <div class="panel-head-simple">
        <div>
          <span class="panel-badge">Facturas</span>
          <h3>Historial de facturación</h3>
        </div>
      </div>

      <% if (invoices && invoices.length) { %>
        <div class="invoice-table">
          <div class="invoice-row invoice-head">
            <div>Factura</div>
            <div>Fecha</div>
            <div>Monto</div>
            <div>Estado</div>
            <div>Acciones</div>
          </div>

          <% invoices.forEach(invoice => { %>
            <div class="invoice-row">
              <div><strong><%= invoice.number %></strong></div>
              <div><%= invoice.created %></div>
              <div><strong><%= invoice.currency %> <%= invoice.amount.toFixed(2) %></strong></div>
              <div>
                <span class="status-mini"><%= invoice.status %></span>
              </div>
              <div style="display:flex; gap:8px; flex-wrap:wrap;">
                <% if (invoice.hosted_invoice_url) { %>
                  <a href="<%= invoice.hosted_invoice_url %>" target="_blank" class="btn btn-secondary">Ver</a>
                <% } %>
                <% if (invoice.invoice_pdf) { %>
                  <a href="<%= invoice.invoice_pdf %>" target="_blank" class="btn btn-primary">PDF</a>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-box">
          Aún no hay facturas generadas para esta cuenta.
        </div>
      <% } %>
    </section>

    <section class="panel">
      <div class="panel-head-simple">
        <div>
          <span class="panel-badge">Tarjeta</span>
          <h3>Método de pago</h3>
        </div>
      </div>

      <% if (paymentMethod) { %>
        <div class="payment-method-wrap">
          <div class="pm-card">
            <span class="pm-chip">Tarjeta guardada</span>
            <div class="info-list">
              <div class="info-row">
                <span>Marca</span>
                <strong><%= paymentMethod.brand %></strong>
              </div>
              <div class="info-row">
                <span>Terminación</span>
                <strong>**** **** **** <%= paymentMethod.last4 %></strong>
              </div>
              <div class="info-row">
                <span>Expira</span>
                <strong><%= paymentMethod.exp_month %>/<%= paymentMethod.exp_year %></strong>
              </div>
            </div>
          </div>
        </div>
      <% } else { %>
        <div class="empty-box">
          No se encontró una tarjeta predeterminada guardada para esta cuenta.
        </div>
      <% } %>

      <div style="margin-top:16px;">
        <a href="/dashboard" class="btn btn-secondary btn-blockish">Volver</a>
      </div>
    </section>

  </div>

</div>
</section>
</main>

</body>
</html>