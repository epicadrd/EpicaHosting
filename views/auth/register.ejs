<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Crear cuenta' %> | <%= appName || 'Epic Hosting' %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/auth.css" />

  <style>
    .auth-card-pro input.form-control {
      color: #ffffff !important;
      background: rgba(255,255,255,0.05) !important;
      border: 1px solid rgba(255,255,255,0.12) !important;
      box-shadow: none;
    }

    .auth-card-pro input.form-control::placeholder {
      color: rgba(255,255,255,0.45) !important;
    }

    .auth-card-pro input.form-control:focus {
      color: #ffffff !important;
      background: rgba(255,255,255,0.08) !important;
      border-color: rgba(37,150,190,0.85) !important;
      box-shadow: 0 0 0 0.2rem rgba(37,150,190,0.18) !important;
    }

    .auth-card-pro .form-label,
    .auth-card-pro label {
      color: #e5eef8;
    }

    .auth-card-pro .form-control.is-invalid,
    .was-validated .auth-card-pro .form-control:invalid {
      border-color: #dc3545 !important;
      background-image: none !important;
    }

    .auth-card-pro .form-control.is-valid,
    .was-validated .auth-card-pro .form-control:valid {
      border-color: #198754 !important;
      background-image: none !important;
    }

    .auth-card-pro .invalid-feedback {
      display: none;
      color: #ffb4b4;
      font-size: 0.84rem;
      margin-top: 0.45rem;
    }

    .was-validated .auth-card-pro .form-control:invalid ~ .invalid-feedback,
    .auth-card-pro .form-control.is-invalid ~ .invalid-feedback {
      display: block;
    }

    .password-strength {
      margin-top: 0.7rem;
    }

    .password-bar {
      width: 100%;
      height: 6px;
      border-radius: 999px;
      background: rgba(255,255,255,0.10);
      overflow: hidden;
    }

    .password-bar-fill {
      width: 0%;
      height: 100%;
      border-radius: 999px;
      transition: width 0.25s ease, background 0.25s ease;
    }

    .password-text {
      margin-top: 0.45rem;
      font-size: 0.82rem;
      color: rgba(255,255,255,0.72);
    }
  </style>
</head>
<body>

  <header class="navbar">
    <div class="container nav-wrap">
      <a href="/" class="brand">
        <span class="brand-mark">⚡</span>
        <span><%= appName || 'Epic Hosting' %></span>
      </a>

      <nav class="nav-links">
        <a href="/">Inicio</a>
        <a href="/login" class="nav-cta">Entrar</a>
      </nav>
    </div>
  </header>

  <main class="auth-main">
    <section class="auth-section">
      <div class="container auth-shell">
        <div class="auth-grid register-grid">

          <div class="auth-copy">
            <span class="kicker">
              <span class="kicker-dot"></span>
              Empieza en minutos
            </span>

            <h1>
              Crea tu cuenta y
              <span class="gradient">lanza tu servicio con soporte</span>
            </h1>

            <p>
              Registra tu empresa, configura tu acceso y empieza a gestionar tu infraestructura
              con una experiencia profesional, estable y preparada para crecimiento.
            </p>

            <div class="auth-feature-list">
              <div class="auth-feature-item">
                <span class="feature-icon">✓</span>
                <div>
                  <strong>Cuenta empresarial</strong>
                  <p>Regístrate y administra tu servicio desde tu panel.</p>
                </div>
              </div>

              <div class="auth-feature-item">
                <span class="feature-icon">✓</span>
                <div>
                  <strong>Acceso centralizado</strong>
                  <p>Un solo lugar para controlar plan, usuarios y operación.</p>
                </div>
              </div>

              <div class="auth-feature-item">
                <span class="feature-icon">✓</span>
                <div>
                  <strong>Base lista para crecer</strong>
                  <p>Facil de usar y sin complicaciones.</p>
                </div>
              </div>
            </div>
          </div>

          <div class="auth-card-wrap">
            <div class="glow glow-1"></div>
            <div class="glow glow-2"></div>

            <div class="auth-card-pro auth-card-register">
              <div class="mini-topbar">
                <span class="mini-dot"></span>
                <span class="mini-dot"></span>
                <span class="mini-dot"></span>
              </div>

              <div class="auth-card-head">
                <div class="auth-badge">Registro</div>
                <h2>Crea tu cuenta</h2>
                <p>Completa tus datos para comenzar.</p>
              </div>

              <%- include('../partials/flash') %>

              <form action="/register" method="POST" class="auth-form-pro needs-validation" novalidate id="registerForm">

                <div class="form-group mb-3">
                  <label for="tenantName">Nombre de la empresa</label>
                  <input
                    type="text"
                    id="tenantName"
                    name="tenantName"
                    class="form-control"
                    placeholder="Ej. Épica Hosting"
                    required
                  />
                  <div class="invalid-feedback">Ingresa el nombre de la empresa.</div>
                </div>

                <div class="form-group two-cols mb-3">
                  <div>
                    <label for="name">Nombre del administrador</label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      class="form-control"
                      placeholder="Tu nombre"
                      required
                    />
                    <div class="invalid-feedback">Ingresa tu nombre.</div>
                  </div>

                  <div>
                    <label for="email">Correo electrónico</label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      class="form-control"
                      placeholder="tuempresa@correo.com"
                      required
                    />
                    <div class="invalid-feedback">Ingresa un correo válido.</div>
                  </div>
                </div>

                <div class="form-group two-cols mb-3">
                  <div>
                    <label for="password">Contraseña</label>
                    <input
                      type="password"
                      id="password"
                      name="password"
                      class="form-control"
                      placeholder="••••••••"
                      minlength="6"
                      required
                    />
                    <div class="password-strength">
                      <div class="password-bar">
                        <div id="passwordBar" class="password-bar-fill"></div>
                      </div>
                      <div id="passwordText" class="password-text">Fuerza de contraseña</div>
                    </div>
                    <div class="invalid-feedback">Mínimo 6 caracteres.</div>
                  </div>

                  <div>
                    <label for="confirmPassword">Confirmar contraseña</label>
                    <input
                      type="password"
                      id="confirmPassword"
                      name="confirmPassword"
                      class="form-control"
                      placeholder="••••••••"
                      required
                    />
                    <div class="invalid-feedback" id="confirmPasswordFeedback">
                      Confirma tu contraseña.
                    </div>
                  </div>
                </div>

                <button type="submit" class="btn btn-primary btn-auth-submit">
                  Crear cuenta
                </button>
              </form>

              <div class="auth-bottom">
                <p>¿Ya tienes cuenta?</p>
                <a href="/login">Iniciar sesión</a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-wrap">
      <p>© 2026 <%= appName || 'Epic Hosting' %>. Todos los derechos reservados.</p>
      <div class="footer-links">
        <a href="/">Inicio</a>
      </div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    (() => {
      'use strict';

      const form = document.getElementById('registerForm');
      const password = document.getElementById('password');
      const confirmPassword = document.getElementById('confirmPassword');
      const feedback = document.getElementById('confirmPasswordFeedback');
      const passwordBar = document.getElementById('passwordBar');
      const passwordText = document.getElementById('passwordText');

      const checkStrength = (value) => {
        if (!value) {
          passwordBar.style.width = '0%';
          passwordBar.style.background = 'transparent';
          passwordText.textContent = 'Fuerza de contraseña';
          return;
        }

        let strength = 0;

        if (value.length >= 6) strength++;
        if (/[A-Z]/.test(value)) strength++;
        if (/[0-9]/.test(value)) strength++;
        if (/[^A-Za-z0-9]/.test(value)) strength++;

        switch (strength) {
          case 1:
            passwordBar.style.width = '25%';
            passwordBar.style.background = '#ef4444';
            passwordText.textContent = 'Débil';
            break;
          case 2:
            passwordBar.style.width = '50%';
            passwordBar.style.background = '#f59e0b';
            passwordText.textContent = 'Media';
            break;
          case 3:
            passwordBar.style.width = '75%';
            passwordBar.style.background = '#3b82f6';
            passwordText.textContent = 'Buena';
            break;
          case 4:
            passwordBar.style.width = '100%';
            passwordBar.style.background = '#22c55e';
            passwordText.textContent = 'Fuerte';
            break;
          default:
            passwordBar.style.width = '15%';
            passwordBar.style.background = '#ef4444';
            passwordText.textContent = 'Muy débil';
        }
      };

      const validatePasswords = () => {
        if (!confirmPassword.value) {
          confirmPassword.setCustomValidity('invalid');
          feedback.textContent = 'Confirma tu contraseña.';
          return;
        }

        if (password.value !== confirmPassword.value) {
          confirmPassword.setCustomValidity('invalid');
          feedback.textContent = 'Las contraseñas no coinciden.';
        } else {
          confirmPassword.setCustomValidity('');
          feedback.textContent = 'Confirma tu contraseña.';
        }
      };

      password.addEventListener('input', () => {
        checkStrength(password.value);
        validatePasswords();
      });

      confirmPassword.addEventListener('input', validatePasswords);

      form.addEventListener('submit', function (event) {
        checkStrength(password.value);
        validatePasswords();

        if (!form.checkValidity()) {
          event.preventDefault();
          event.stopPropagation();
        }

        form.classList.add('was-validated');
      }, false);
    })();
  </script>

</body>
</html>