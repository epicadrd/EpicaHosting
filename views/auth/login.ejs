<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Iniciar sesión' %> | <%= appName || 'Epic Hosting' %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >

  <!-- Bootstrap Icons -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  >

  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/auth.css" />

  <style>
    .auth-form-pro .form-group {
      margin-bottom: 1rem;
    }

    .auth-form-pro .form-control {
      min-height: 52px;
      border-radius: 14px;
      padding: 0.9rem 1rem;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.04);
      color: #fff;
      transition: .2s ease;
      box-shadow: none;
    }

    .auth-form-pro .form-control::placeholder {
      color: rgba(255,255,255,.45);
    }

    .auth-form-pro .form-control:focus {
      border-color: rgba(13,110,253,.7);
      box-shadow: 0 0 0 .2rem rgba(13,110,253,.15);
      background: rgba(255,255,255,.06);
      color: #fff;
    }

    .auth-form-pro label {
      display: block;
      margin-bottom: .45rem;
      font-weight: 600;
      color: #fff;
    }

    .password-wrap {
      position: relative;
    }

    .password-wrap .form-control {
      padding-right: 3.25rem;
    }

    .toggle-password {
      position: absolute;
      top: 50%;
      right: .85rem;
      transform: translateY(-50%);
      border: none;
      background: transparent;
      color: rgba(255,255,255,.7);
      font-size: 1.1rem;
      cursor: pointer;
      padding: 0;
      line-height: 1;
    }

    .toggle-password:hover {
      color: #fff;
    }

    .invalid-feedback,
    .valid-feedback {
      display: none;
      font-size: .875rem;
      margin-top: .45rem;
    }

    .form-control.is-invalid ~ .invalid-feedback {
      display: block;
    }

    .form-control.is-valid ~ .valid-feedback {
      display: block;
    }

    .server-error-box {
      background: rgba(220,53,69,.12);
      border: 1px solid rgba(220,53,69,.35);
      color: #ffd7dc;
      border-radius: 14px;
      padding: .9rem 1rem;
      margin-bottom: 1rem;
      font-size: .95rem;
      font-weight: 500;
    }

    .server-success-box {
      background: rgba(25,135,84,.12);
      border: 1px solid rgba(25,135,84,.35);
      color: #d7ffea;
      border-radius: 14px;
      padding: .9rem 1rem;
      margin-bottom: 1rem;
      font-size: .95rem;
      font-weight: 500;
    }

    .input-hint {
      margin-top: .45rem;
      font-size: .82rem;
      color: rgba(255,255,255,.58);
    }
  </style>
</head>
<body>

  <header class="navbar">
    <div class="container nav-wrap">
      <a href="/" class="brand">
        <span class="brand-mark">⚡</span>
        <span><%= appName || 'Epic Hosting' %></span>
      </a>

      <nav class="nav-links">
        <a href="/">Inicio</a>
        <% if (currentUser) { %>
          <a href="/dashboard" class="nav-cta">Dashboard</a>
        <% } else { %>
          <a href="/register" class="nav-cta">Crear cuenta</a>
        <% } %>
      </nav>
    </div>
  </header>

  <main class="auth-main">
    <section class="auth-section">
      <div class="container auth-shell">
        <div class="auth-grid">

          <div class="auth-copy">
            <span class="kicker">
              <span class="kicker-dot"></span>
              Acceso seguro a tu panel
            </span>

            <h1>
              Inicia sesión y
              <span class="gradient">gestiona tu infraestructura</span>
            </h1>

            <p>
              Accede a tu cuenta para administrar tu servicio, revisar tu plan,
              gestionar tu proyecto y mantener el control de tu hosting desde un solo lugar.
            </p>

            <div class="trust-row auth-trust">
              <span class="trust-pill">Acceso seguro</span>
              <span class="trust-pill">Gestión centralizada</span>
              <span class="trust-pill">Soporte técnico</span>
            </div>
          </div>

          <div class="auth-card-wrap">
            <div class="glow glow-1"></div>
            <div class="glow glow-2"></div>

            <div class="auth-card-pro">
              <div class="mini-topbar">
                <span class="mini-dot"></span>
                <span class="mini-dot"></span>
                <span class="mini-dot"></span>
              </div>

              <div class="auth-card-head">
                <div class="auth-badge">Login</div>
                <h2>Bienvenido de nuevo</h2>
                <p>Introduce tus credenciales para entrar a tu panel.</p>
              </div>

              <% if (flash && flash.type === 'error') { %>
                <div class="server-error-box">
                  <i class="bi bi-exclamation-triangle-fill me-2"></i>
                  <%= flash.message %>
                </div>
              <% } %>

              <% if (flash && flash.type === 'success') { %>
                <div class="server-success-box">
                  <i class="bi bi-check-circle-fill me-2"></i>
                  <%= flash.message %>
                </div>
              <% } %>

              <form action="/login" method="POST" class="auth-form-pro needs-validation" id="loginForm" novalidate>
                <div class="form-group">
                  <label for="email">Correo electrónico</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    class="form-control"
                    placeholder="tuempresa@correo.com"
                    autocomplete="email"
                    required
                  />
                  <div class="invalid-feedback">
                    Debes introducir un correo electrónico válido.
                  </div>
                  <div class="valid-feedback">
                    Correo válido.
                  </div>
                </div>

                <div class="form-group">
                  <label for="password">Contraseña</label>

                  <div class="password-wrap">
                    <input
                      type="password"
                      id="password"
                      name="password"
                      class="form-control"
                      placeholder="••••••••"
                      autocomplete="current-password"
                      minlength="6"
                      required
                    />

                    <button type="button" class="toggle-password" id="togglePassword" aria-label="Mostrar contraseña">
                      <i class="bi bi-eye"></i>
                    </button>

                    <div class="invalid-feedback">
                      Debes introducir una contraseña válida.
                    </div>
                    <div class="valid-feedback">
                      Contraseña válida.
                    </div>
                  </div>

                  <div class="input-hint">Mínimo 6 caracteres.</div>
                </div>

                <button type="submit" class="btn btn-primary btn-auth-submit w-100">
                  Iniciar sesión
                </button>
              </form>

              <div class="auth-bottom">
                <p>¿Aún no tienes cuenta?</p>
                <a href="/register">Crear cuenta</a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-wrap">
      <p>© 2026 <%= appName || 'Epic Hosting' %>. Todos los derechos reservados.</p>
      <div class="footer-links">
        <a href="/">Inicio</a>
      </div>
    </div>
  </footer>

  <script>
    (() => {
      const form = document.getElementById('loginForm');
      const email = document.getElementById('email');
      const password = document.getElementById('password');
      const togglePassword = document.getElementById('togglePassword');

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      function validateEmail() {
        const value = email.value.trim();

        if (!value) {
          email.classList.remove('is-valid');
          email.classList.add('is-invalid');
          return false;
        }

        if (!emailRegex.test(value)) {
          email.classList.remove('is-valid');
          email.classList.add('is-invalid');
          return false;
        }

        email.classList.remove('is-invalid');
        email.classList.add('is-valid');
        return true;
      }

      function validatePassword() {
        const value = password.value.trim();

        if (!value || value.length < 6) {
          password.classList.remove('is-valid');
          password.classList.add('is-invalid');
          return false;
        }

        password.classList.remove('is-invalid');
        password.classList.add('is-valid');
        return true;
      }

      email.addEventListener('input', validateEmail);
      email.addEventListener('blur', validateEmail);

      password.addEventListener('input', validatePassword);
      password.addEventListener('blur', validatePassword);

      form.addEventListener('submit', function (e) {
        const isEmailValid = validateEmail();
        const isPasswordValid = validatePassword();

        if (!isEmailValid || !isPasswordValid) {
          e.preventDefault();
          e.stopPropagation();
        }
      });

      togglePassword.addEventListener('click', () => {
        const isPassword = password.getAttribute('type') === 'password';
        password.setAttribute('type', isPassword ? 'text' : 'password');

        togglePassword.innerHTML = isPassword
          ? '<i class="bi bi-eye-slash"></i>'
          : '<i class="bi bi-eye"></i>';
      });
    })();
  </script>

</body>
</html>